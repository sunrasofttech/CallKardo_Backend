    {
      "name": "6. AI Agents",
      "description": "**FLOW:** Create an AI agent → List agents → Update agent config → Assign agent to a VoBiz number.",
      "item": [
        {
          "name": "6.1 Create Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('agentId', json.data.id);",
                  "  console.log('✅ agentId saved:', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sales Assistant\",\n  \"description\": \"Qualifies leads and books appointments\",\n  \"systemPrompt\": \"You are a professional sales assistant. Your goal is to qualify leads by asking about their budget, timeline, and needs. Be friendly and concise. Keep responses under 30 words.\",\n  \"language\": \"en\",\n  \"voiceId\": \"{{voiceId}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"activeStatus\": true,\n  \"allowInterruption\": true,\n  \"pace\": 1.0,\n  \"temperature\": 0.6,\n  \"firstMessage\": \"Hello! Thanks for taking my call. I'm calling from AI Live. Do you have a moment to chat?\",\n  \"aiProvider\": \"geminilive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "agents"]
            },
            "description": "Create a new AI voice agent with a system prompt, voice, and configuration.\n\n**Auto-saves:** `agentId`\n\n**aiProvider options:** `geminilive`, `custom`, `customv2`, `elevenlabs`"
          },
          "response": []
        },
        {
          "name": "6.2 List All Agents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "agents"]
            },
            "description": "List all AI agents belonging to the authenticated merchant."
          },
          "response": []
        },
        {
          "name": "6.3 Get Agent by ID",
          "request": {
            "method": "GET",
