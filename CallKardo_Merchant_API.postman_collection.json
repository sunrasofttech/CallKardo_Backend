{
  "info": {
    "name": "CallKardo Merchant API",
    "description": "Complete merchant API collection for CallKardo / AI Live Platform.\n\n## Working Flow Order\nFollow the numbered folders in sequence for a complete end-to-end merchant onboarding and campaign execution flow:\n\n1. **Auth** → Register → Verify OTP → Login → Setup Business\n2. **Categories & Plans** → Browse available categories and plans\n3. **Subscription** → View current plan, upgrade if needed\n4. **VoBiz Setup** → Connect telephony account → Buy/add numbers\n5. **Voices** → Browse and preview voices\n6. **Agents** → Create AI voice agents\n7. **Customers** → Add contacts manually or via CSV upload\n8. **Campaigns** → Create and launch outbound campaigns\n9. **Reports & Analytics** → View call results and dashboard stats\n\nSet the `baseUrl` and `accessToken` variables before use.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.callkardo.com",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "planId",
      "value": "",
      "type": "string"
    },
    {
      "key": "voiceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "agentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerListId",
      "value": "",
      "type": "string"
    },
    {
      "key": "vobizNumberId",
      "value": "",
      "type": "string"
    },
    {
      "key": "campaignId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth (Start Here)",
      "description": "**FLOW:** Register → Verify OTP → Login → Get Profile → Setup Business",
      "item": [
        {
          "name": "1.1 Register Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('✅ Tokens saved from registration');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"mobile\": \"+919876543210\",\n  \"password\": \"securePass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new merchant. Returns access & refresh tokens immediately. An OTP is sent via SMS for verification.\n\n**Auto-saves:** `accessToken`, `refreshToken`"
          },
          "response": []
        },
        {
          "name": "1.2 Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\",\n  \"role\": \"merchant\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-otp"]
            },
            "description": "Verify the 6-digit OTP sent via SMS. Must be called with a valid accessToken (from registration)."
          },
          "response": []
        },
        {
          "name": "1.3 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('✅ Tokens saved from login');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"+919876543210\",\n  \"password\": \"securePass123\",\n  \"role\": \"merchant\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with email/mobile and password. Use `role: merchant` or `role: super_admin`.\n\n**Auto-saves:** `accessToken`, `refreshToken`"
          },
          "response": []
        },
        {
          "name": "1.4 Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get the authenticated user's full profile including subscription info, business details, and KYC status."
          },
          "response": []
        },
        {
          "name": "1.5 Setup Business Profile",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"My AI Call Center\",\n  \"businessUrl\": \"https://mycompany.com\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/setup-business",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "setup-business"]
            },
            "description": "Complete business onboarding. Set the business name, website URL, and business category.\n\n**Prerequisite:** Get a `categoryId` from the Categories endpoints first."
          },
          "response": []
        },
        {
          "name": "1.6 Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  if (json.data.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('✅ Access token refreshed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh-token"]
            },
            "description": "Exchange a valid refresh token for a new access token.\n\n**Auto-saves:** `accessToken`"
          },
          "response": []
        },
        {
          "name": "1.7 Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"role\": \"merchant\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "forgot-password"]
            },
            "description": "Request a password reset link. An email with a reset token will be sent."
          },
          "response": []
        },
        {
          "name": "1.8 Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"paste-reset-token-here\",\n  \"password\": \"newSecurePass456\",\n  \"role\": \"merchant\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "reset-password"]
            },
            "description": "Reset password using the token received via email from forgot-password."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Categories & Plans",
      "description": "**FLOW:** Browse categories to pick one for business setup → Browse plans to know available tiers.",
      "item": [
        {
          "name": "2.1 List Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('categoryId', json.data[0].id);",
                  "    console.log('✅ categoryId saved:', json.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories"]
            },
            "description": "List all business categories (e.g. Lawyer, Real Estate, Healthcare).\n\n**Auto-saves:** `categoryId` from first result."
          },
          "response": []
        },
        {
          "name": "2.2 Get Category by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", "{{categoryId}}"]
            },
            "description": "Get details of a specific category including its default prompt and voice."
          },
          "response": []
        },
        {
          "name": "2.3 List Plans",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.length > 0) {",
                  "    const paid = json.data.find(p => p.name !== 'Starter');",
                  "    if (paid) pm.collectionVariables.set('planId', paid.id);",
                  "    console.log('✅ planId saved:', paid ? paid.id : json.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "plans"]
            },
            "description": "List all subscription plans (Starter, Basic, Pro, Enterprise).\n\n**Auto-saves:** `planId` from first paid plan."
          },
          "response": []
        },
        {
          "name": "2.4 Get Plan by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/plans/{{planId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "plans", "{{planId}}"]
            },
            "description": "Get details of a specific plan including price, call limit, and max concurrent calls."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Subscription",
      "description": "**FLOW:** Check current subscription → Upgrade to a paid plan.",
      "item": [
        {
          "name": "3.1 Get My Subscription",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/my",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "subscriptions", "my"]
            },
            "description": "Get the currently authenticated merchant's subscription status, plan details, and usage counters."
          },
          "response": []
        },
        {
          "name": "3.2 Upgrade Subscription",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/subscriptions/upgrade",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "subscriptions", "upgrade"]
            },
            "description": "Upgrade to a different plan. Resets call counters and extends expiry by 1 month."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. VoBiz Telephony Setup",
      "description": "**FLOW:** Connect your VoBiz account OR create a sub-account → Search and buy phone numbers → Manage numbers.",
      "item": [
        {
          "name": "4.1 Connect VoBiz Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"VOBIZ_CUSTOMER_ID\",\n  \"apiKey\": \"your_vobiz_api_key\",\n  \"apiSecret\": \"your_vobiz_api_secret\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/connect",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "connect"]
            },
            "description": "Connect an existing VoBiz telephony account using API credentials. This enables outbound calling."
          },
          "response": []
        },
        {
          "name": "4.2 Create VoBiz Sub-Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/create-subaccount",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "create-subaccount"]
            },
            "description": "Auto-create a new VoBiz sub-account under the platform's parent account. Alternative to connecting an existing account."
          },
          "response": []
        },
        {
          "name": "4.3 Get VoBiz Account Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "account"]
            },
            "description": "Get the connected VoBiz account details and credentials status."
          },
          "response": []
        },
        {
          "name": "4.4 Search Available Numbers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/available-numbers?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "available-numbers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Search for available phone numbers to purchase from VoBiz inventory. Supports pagination."
          },
          "response": []
        },
        {
          "name": "4.5 Buy a Number",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"+911234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/buy-number",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "buy-number"]
            },
            "description": "Purchase a phone number from the available inventory. The number will be registered to your VoBiz account."
          },
          "response": []
        },
        {
          "name": "4.6 List My Numbers",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('vobizNumberId', json.data[0].id);",
                  "    console.log('✅ vobizNumberId saved:', json.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/numbers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "numbers"]
            },
            "description": "List all phone numbers registered to your account.\n\n**Auto-saves:** `vobizNumberId` from first result."
          },
          "response": []
        },
        {
          "name": "4.7 Add Number Manually",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"+919876543210\",\n  \"status\": \"active\",\n  \"agentId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/numbers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "numbers"]
            },
            "description": "Manually register a phone number to your account. Optionally assign an agent immediately."
          },
          "response": []
        },
        {
          "name": "4.8 Update Number",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"agentId\": \"{{agentId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/numbers/{{vobizNumberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "numbers", "{{vobizNumberId}}"]
            },
            "description": "Update a number's status or reassign it to a different agent."
          },
          "response": []
        },
        {
          "name": "4.9 Delete Number",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vobiz/numbers/{{vobizNumberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "vobiz", "numbers", "{{vobizNumberId}}"]
            },
            "description": "Remove a phone number from your account."
          },
          "response": []
        }
      ]
    },
    {
