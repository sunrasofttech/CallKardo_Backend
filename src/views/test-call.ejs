<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agent Tester - <%= agentId %>
  </title>
  <!-- Import Premium Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --bg-gradient: radial-gradient(circle at top left, #0f172a, #0b0f19, #05070c);
      --card-bg: rgba(30, 41, 59, 0.45);
      --card-border: rgba(255, 255, 255, 0.08);
      --primary: #6366f1;
      --primary-hover: #4f46e5;
      --primary-glow: rgba(99, 102, 241, 0.4);
      --danger: #f43f5e;
      --danger-hover: #e11d48;
      --danger-glow: rgba(244, 63, 94, 0.4);
      --success: #10b981;
      --success-glow: rgba(16, 185, 129, 0.4);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-gradient);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      overflow-x: hidden;
    }

    .container {
      width: 100%;
      max-width: 760px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      z-index: 1;
    }

    /* Abstract Background Glow Elements */
    .glow-orb {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
      top: -100px;
      left: -100px;
      filter: blur(50px);
      z-index: 0;
      pointer-events: none;
    }

    .card {
      background: var(--card-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.05);
      position: relative;
      overflow: hidden;
    }

    h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 8px;
    }

    .subtitle {
      color: var(--text-muted);
      font-size: 14px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .agent-pill {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 4px 10px;
      border-radius: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: #38bdf8;
    }

    /* Status Badge */
    .status-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 16px;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border-radius: 99px;
      font-size: 13px;
      font-weight: 600;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.05);
      transition: all 0.3s ease;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--danger);
      box-shadow: 0 0 8px var(--danger);
      transition: all 0.3s ease;
    }

    .status-badge.connected .status-dot {
      background: var(--success);
      box-shadow: 0 0 10px var(--success);
    }

    /* Visualizer Section */
    .visualizer-container {
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 24px 0;
      height: 140px;
    }

    .voice-sphere {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      background: radial-gradient(circle, #64748b 0%, #475569 70%);
      box-shadow: 0 0 20px rgba(100, 116, 139, 0.2);
      transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
    }

    .voice-sphere::after {
      content: '';
      position: absolute;
      top: -4px;
      left: -4px;
      right: -4px;
      bottom: -4px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.1);
      opacity: 0.5;
      animation: pulse-ring 2.5s infinite;
    }

    .voice-sphere.idle {
      animation: float 4s ease-in-out infinite;
    }

    .voice-sphere.connected {
      background: radial-gradient(circle, #818cf8 0%, #4f46e5 70%);
      box-shadow: 0 0 35px var(--primary-glow), inset 0 0 20px rgba(255, 255, 255, 0.3);
      animation: float 2.5s ease-in-out infinite;
    }

    .voice-sphere.speaking {
      background: radial-gradient(circle, #38bdf8 0%, #0284c7 70%);
      box-shadow: 0 0 50px rgba(56, 189, 248, 0.6), inset 0 0 25px rgba(255, 255, 255, 0.5);
      animation: float 1.2s ease-in-out infinite, voice-pulse 0.35s infinite alternate;
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-10px);
      }
    }

    @keyframes pulse-ring {
      0% {
        transform: scale(1);
        opacity: 0.5;
      }

      100% {
        transform: scale(1.4);
        opacity: 0;
      }
    }

    @keyframes voice-pulse {
      0% {
        transform: scale(1.05) translateY(-5px);
      }

      100% {
        transform: scale(1.22) translateY(-5px);
      }
    }

    /* Buttons / Controls */
    .controls {
      display: flex;
      gap: 16px;
      margin-top: 16px;
    }

    .btn {
      flex: 1;
      padding: 14px 28px;
      border-radius: 14px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 15px;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-start {
      background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
      color: white;
      box-shadow: 0 10px 20px -5px var(--primary-glow);
    }

    .btn-start:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px -3px var(--primary-glow);
      filter: brightness(1.1);
    }

    .btn-stop {
      background: linear-gradient(135deg, #e11d48 0%, #f43f5e 100%);
      color: white;
      box-shadow: 0 10px 20px -5px var(--danger-glow);
    }

    .btn-stop:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px -3px var(--danger-glow);
      filter: brightness(1.1);
    }

    .btn:disabled {
      background: rgba(255, 255, 255, 0.04) !important;
      border: 1px solid rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.2) !important;
      cursor: not-allowed;
      box-shadow: none !important;
      transform: none !important;
    }

    /* Live Transcript Area */
    .transcript-header {
      font-family: 'Outfit', sans-serif;
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    #transcript {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      height: 320px;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 255, 255, 0.1) rgba(0, 0, 0, 0);
    }

    #transcript::-webkit-scrollbar {
      width: 6px;
    }

    #transcript::-webkit-scrollbar-track {
      background: transparent;
    }

    #transcript::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 99px;
    }

    /* Chat bubble designs */
    .msg {
      display: flex;
      flex-direction: column;
      max-width: 85%;
      animation: bubble-appear 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes bubble-appear {
      from {
        transform: translateY(8px) scale(0.95);
        opacity: 0;
      }

      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    .msg-agent {
      align-self: flex-start;
    }

    .msg-customer {
      align-self: flex-end;
    }

    .msg-system {
      align-self: center;
      max-width: 100%;
      margin: 4px 0;
    }

    .chat-bubble {
      padding: 12px 18px;
      border-radius: 18px;
      font-size: 14.5px;
      line-height: 1.5;
    }

    .msg-agent .chat-bubble {
      background: rgba(99, 102, 241, 0.12);
      border: 1px solid rgba(99, 102, 241, 0.2);
      color: #e2e8f0;
      border-bottom-left-radius: 4px;
    }

    .msg-customer .chat-bubble {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: #e2e8f0;
      border-bottom-right-radius: 4px;
    }

    .bubble-sender {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }

    .msg-agent .bubble-sender {
      color: #818cf8;
    }

    .msg-customer .bubble-sender {
      color: #34d399;
    }

    .system-pill {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      color: var(--text-muted);
      font-size: 12px;
      padding: 6px 14px;
      border-radius: 99px;
      font-weight: 500;
    }

    /* Modal styles */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(5, 8, 15, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 1000;
    }

    .modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-card {
      background: rgba(20, 28, 48, 0.95);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 28px;
      padding: 40px 32px;
      width: 90%;
      max-width: 420px;
      text-align: center;
      box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.8), inset 0 1px 1px rgba(255, 255, 255, 0.05);
      transform: scale(0.9);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .modal-overlay.active .modal-card {
      transform: scale(1);
    }

    .modal-icon {
      background: rgba(99, 102, 241, 0.15);
      color: #818cf8;
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px auto;
      position: relative;
    }

    .modal-icon::after {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 1px solid #818cf8;
      opacity: 0.3;
      animation: pulse-ring 2s infinite;
    }

    .modal-card h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--text-main);
      margin-bottom: 12px;
    }

    .modal-card p {
      color: var(--text-muted);
      font-size: 14.5px;
      margin-bottom: 28px;
      line-height: 1.5;
    }

    .countdown-wrapper {
      font-weight: 700;
      color: #38bdf8;
      margin-bottom: 28px;
      font-size: 17px;
      font-family: 'Outfit', sans-serif;
    }

    .modal-actions {
      display: flex;
      gap: 16px;
    }

    .btn-modal-cancel {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: #cbd5e1;
    }

    .btn-modal-cancel:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.25);
    }

    .btn-modal-confirm {
      background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
      color: white;
      box-shadow: 0 4px 14px rgba(79, 70, 229, 0.3);
    }

    .btn-modal-confirm:hover {
      filter: brightness(1.1);
      box-shadow: 0 6px 20px rgba(79, 70, 229, 0.4);
    }
  </style>
</head>

<body>
  <div class="glow-orb"></div>

  <div class="container">
    <!-- Top Tester Card -->
    <div class="card">
      <h1>AI Agent Voice Tester</h1>
      <div class="subtitle">
        <span>Testing Agent ID:</span>
        <span class="agent-pill">
          <%= agentId %>
        </span>
      </div>

      <div class="visualizer-container">
        <div id="voiceSphere" class="voice-sphere idle"></div>
      </div>

      <div class="status-container">
        <div class="status-badge">
          <span class="status-dot"></span>
          <span id="status">Status: Disconnected</span>
        </div>
      </div>

      <div class="controls">
        <button id="btnStart" class="btn btn-start">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
            stroke="currentColor" style="width: 18px; height: 18px;">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.187-4.165-6.99-6.99l1.293-.97c.362-.272.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          Start Call
        </button>
        <button id="btnStop" class="btn btn-stop" disabled>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
            stroke="currentColor" style="width: 18px; height: 18px;">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          Stop Call
        </button>
      </div>
    </div>

    <!-- Live Transcript Card -->
    <div class="card">
      <div class="transcript-header">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"
          style="width: 20px; height: 20px; color: var(--primary);">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v5.009Z" />
        </svg>
        Live Conversation
      </div>
      <div id="transcript"></div>
    </div>
  </div>

  <!-- Beautiful Inactivity Confirmation Modal -->
  <div id="inactivityModal" class="modal-overlay">
    <div class="modal-card">
      <div class="modal-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"
          style="width: 28px; height: 28px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
      <h2>Inactivity Detected</h2>
      <p>Would you like to connect and start a call with the AI voice agent?</p>
      <div class="countdown-wrapper">
        Auto-calling in <span id="countdownSecs">10</span>s...
      </div>
      <div class="modal-actions">
        <button id="btnModalCancel" class="btn btn-modal-cancel">Cancel</button>
        <button id="btnModalConfirm" class="btn btn-modal-confirm">Call Now</button>
      </div>
    </div>
  </div>

  <script>
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = `${protocol}//${window.location.host}/ws/webcall?agentId=<%= agentId %>`;
    let ws = null;
    let audioContext = null;
    let microphone = null;
    let processor = null;
    let silentGain = null;
    let nextPlayTime = 0;
    let speechHangoverFrames = 0;
    let playbackSources = [];

    const btnStart = document.getElementById('btnStart');
    const btnStop = document.getElementById('btnStop');
    const statusDiv = document.getElementById('status');
    const transcriptDiv = document.getElementById('transcript');

    // Inactivity tracking variables
    let inactivityTimer = null;
    const INACTIVITY_LIMIT_MS = 10000; // 10 seconds of no interaction
    let isCallActive = false;
    let confirmationModalActive = false;
    let countdownInterval = null;
    let countdownValue = 10;

    const inactivityModal = document.getElementById('inactivityModal');
    const countdownSecs = document.getElementById('countdownSecs');
    const btnModalCancel = document.getElementById('btnModalCancel');
    const btnModalConfirm = document.getElementById('btnModalConfirm');

    // Inactivity monitor functions
    function resetInactivityTimer() {
      if (isCallActive || confirmationModalActive) {
        clearTimeout(inactivityTimer);
        return;
      }
      clearTimeout(inactivityTimer);
      inactivityTimer = setTimeout(showInactivityConfirmation, INACTIVITY_LIMIT_MS);
    }

    function showInactivityConfirmation() {
      confirmationModalActive = true;
      inactivityModal.classList.add('active');

      countdownValue = 10;
      countdownSecs.textContent = countdownValue;

      if (countdownInterval) clearInterval(countdownInterval);

      countdownInterval = setInterval(() => {
        countdownValue--;
        countdownSecs.textContent = countdownValue;

        if (countdownValue <= 0) {
          clearInterval(countdownInterval);
          autoConfirmCall();
        }
      }, 1000);
    }

    function hideInactivityModal() {
      confirmationModalActive = false;
      inactivityModal.classList.remove('active');
      if (countdownInterval) {
        clearInterval(countdownInterval);
        countdownInterval = null;
      }
      resetInactivityTimer();
    }

    function autoConfirmCall() {
      hideInactivityModal();
      logMessage('system', 'Auto-connecting due to inactivity confirmation...');
      startCall();
    }

    btnModalConfirm.addEventListener('click', () => {
      autoConfirmCall();
    });

    btnModalCancel.addEventListener('click', () => {
      hideInactivityModal();
      logMessage('system', 'Auto-call cancelled.');
    });

    // Register interaction handlers for page inactivity
    const activityEvents = ['mousemove', 'keydown', 'click', 'scroll', 'touchstart'];
    activityEvents.forEach(event => {
      window.addEventListener(event, resetInactivityTimer);
    });

    // Start tracking on page load
    resetInactivityTimer();

    function logMessage(role, text) {
      const div = document.createElement('div');
      div.className = `msg msg-${role}`;

      if (role === 'system') {
        div.innerHTML = `<span class="system-pill">${text}</span>`;
      } else {
        const bubble = document.createElement('div');
        bubble.className = `chat-bubble`;
        bubble.innerHTML = `<div class="bubble-sender">${role === 'agent' ? 'Agent' : 'You'}</div><div class="bubble-text">${text}</div>`;
        div.appendChild(bubble);
      }

      transcriptDiv.appendChild(div);
      transcriptDiv.scrollTop = transcriptDiv.scrollHeight;
    }

    // Downsample microphone Float32 buffer to Int16 PCM 16000Hz
    function downsampleBuffer(buffer, sampleRate) {
      if (sampleRate === 16000) {
        return convertFloat32ToInt16(buffer);
      }
      const sampleRateRatio = sampleRate / 16000;
      const newLength = Math.round(buffer.length / sampleRateRatio);
      const result = new Float32Array(newLength);
      let offsetResult = 0;
      let offsetBuffer = 0;
      while (offsetResult < result.length) {
        const nextOffsetBuffer = Math.round((offsetResult + 1) * sampleRateRatio);
        let accum = 0, count = 0;
        for (let i = offsetBuffer; i < nextOffsetBuffer && i < buffer.length; i++) {
          accum += buffer[i];
          count++;
        }
        result[offsetResult] = accum / count;
        offsetResult++;
        offsetBuffer = nextOffsetBuffer;
      }
      return convertFloat32ToInt16(result);
    }

    function convertFloat32ToInt16(buffer) {
      let l = buffer.length;
      let buf = new Int16Array(l);
      while (l--) {
        buf[l] = Math.min(1, buffer[l]) * 0x7FFF;
      }
      return buf.buffer;
    }

    // Playback incoming Int16 PCM 16000Hz audio
    function playAudioData(int16Array) {
      if (!audioContext) return;
      const float32Array = new Float32Array(int16Array.length);
      for (let i = 0; i < int16Array.length; i++) {
        float32Array[i] = int16Array[i] / 0x7FFF;
      }

      const audioBuffer = audioContext.createBuffer(1, float32Array.length, 16000);
      audioBuffer.getChannelData(0).set(float32Array);

      const source = audioContext.createBufferSource();
      source.buffer = audioBuffer;
      source.connect(audioContext.destination);
      playbackSources.push(source);

      const voiceSphere = document.getElementById('voiceSphere');
      if (voiceSphere) {
        voiceSphere.className = 'voice-sphere speaking';
      }

      source.onended = () => {
        playbackSources = playbackSources.filter((item) => item !== source);
        if (playbackSources.length === 0 && voiceSphere) {
          voiceSphere.className = 'voice-sphere connected';
        }
      };

      const currentTime = audioContext.currentTime;
      if (nextPlayTime < currentTime) nextPlayTime = currentTime;
      source.start(nextPlayTime);
      nextPlayTime += audioBuffer.duration;
    }

    function clearPlaybackQueue() {
      if (audioContext) {
        nextPlayTime = audioContext.currentTime;
      }
      playbackSources.forEach((source) => {
        try {
          source.stop();
        } catch (err) { }
      });
      playbackSources = [];
    }

    async function startCall() {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: true, noiseSuppression: true, autoGainControl: true } });

        audioContext = new (window.AudioContext || window.webkitAudioContext)();

        ws = new WebSocket(wsUrl);
        ws.binaryType = "arraybuffer";

        ws.onopen = () => {
          isCallActive = true;
          clearTimeout(inactivityTimer); // Disable idle warning during calls

          const statusBadge = document.querySelector('.status-badge');
          if (statusBadge) statusBadge.classList.add('connected');

          statusDiv.textContent = 'Status: Connected';
          btnStart.disabled = true;
          btnStop.disabled = false;
          logMessage('system', 'Call connected. Connecting to Agent AI...');

          const voiceSphere = document.getElementById('voiceSphere');
          if (voiceSphere) voiceSphere.className = 'voice-sphere connected';

          microphone = audioContext.createMediaStreamSource(stream);
          processor = audioContext.createScriptProcessor(4096, 1, 1);

          processor.onaudioprocess = (e) => {
            if (ws.readyState === WebSocket.OPEN) {
              const inputBuffer = e.inputBuffer.getChannelData(0);

              // Compute RMS volume for basic Voice Activity Detection (VAD)
              let sum = 0;
              for (let i = 0; i < inputBuffer.length; i++) {
                sum += inputBuffer[i] * inputBuffer[i];
              }
              const rms = Math.sqrt(sum / inputBuffer.length);

              // Keep sending a short tail after speech so STT does not lose quiet word endings.
              if (rms > 0.006) {
                speechHangoverFrames = 12;
              }

              if (rms > 0.003 || speechHangoverFrames > 0) {
                const pcm16Buffer = downsampleBuffer(inputBuffer, audioContext.sampleRate);
                ws.send(pcm16Buffer);
                if (speechHangoverFrames > 0) speechHangoverFrames--;
              }
            }
          };

          microphone.connect(processor);
          silentGain = audioContext.createGain();
          silentGain.gain.value = 0;
          processor.connect(silentGain);
          silentGain.connect(audioContext.destination);
        };

        ws.onmessage = (event) => {
          if (event.data instanceof ArrayBuffer) {
            // Incoming Audio
            const int16Array = new Int16Array(event.data);
            playAudioData(int16Array);
          } else {
            // Incoming Text/JSON
            if (event.data === 'CLEAR') {
              clearPlaybackQueue();
            } else {
              try {
                const msg = JSON.parse(event.data);
                logMessage(msg.type, msg.text);
              } catch (e) { }
            }
          }
        };

        ws.onclose = () => {
          stopCall();
          logMessage('system', 'Call disconnected.');
        };

      } catch (err) {
        alert('Could not access microphone: ' + err.message);
      }
    }

    function stopCall() {
      isCallActive = false;

      const voiceSphere = document.getElementById('voiceSphere');
      if (voiceSphere) voiceSphere.className = 'voice-sphere idle';

      if (ws) {
        if (ws.readyState === WebSocket.OPEN) {
          ws.send('stop');
          ws.close();
        }
        ws = null;
      }
      if (processor) {
        processor.disconnect();
        processor = null;
      }
      if (silentGain) {
        silentGain.disconnect();
        silentGain = null;
      }
      if (microphone) {
        microphone.disconnect();
        microphone = null;
      }
      clearPlaybackQueue();
      if (audioContext) {
        audioContext.close();
        audioContext = null;
      }

      const statusBadge = document.querySelector('.status-badge');
      if (statusBadge) statusBadge.classList.remove('connected');

      statusDiv.textContent = 'Status: Disconnected';
      btnStart.disabled = false;
      btnStop.disabled = true;

      resetInactivityTimer(); // Resume idle warning when call stops
    }

    btnStart.addEventListener('click', startCall);
    btnStop.addEventListener('click', stopCall);
  </script>
</body>

</html>